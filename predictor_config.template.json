{
  "_comment": "Indoor Asthma Trigger — ML Predictor Config",

  "firebase_credentials_path": "serviceAccountKey.json",
  "firebase_database_url": "https://<YOUR-PROJECT-ID>.firebaseio.com",
  "sensor_collection":    "sensor_readings",
  "episode_collection":   "episodes",
  "prediction_collection": "predictions",

  "min_days_data":    3,
  "min_episodes":     10,

  "feature_window_s": 600,
  "label_horizon_s":  600,

  "predict_interval_s": 300,
  "alert_threshold":    0.65,

  "retrain_interval_h": 24,
  "model_path":         "model.joblib",
  "model_version":      "v1",

  "target_labels": ["cough", "sneeze", "wheeze"]
}
